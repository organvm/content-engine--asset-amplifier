{
  "name": "cronus-metabolus",
  "version": "0.1.0",
  "private": true,
  "description": "Content Yield Engine — one premium asset → continuous content → measurable yield",
  "type": "module",
  "author": "Anthony Padavano + Scott Lefler (Lefler Design)",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @cronus/db migrate",
    "db:seed": "tsx infra/scripts/seed.ts",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yaml}\""
  },
  "keywords": [
    "content-engine",
    "social-media",
    "ai",
    "video-processing",
    "brand-identity",
    "organvm"
  ],
  "dependencies": {
    "tsx": "4.23.0",
    "vitest": "4.1.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.64.0"
  }
}
