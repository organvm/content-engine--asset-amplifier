+        <div className="p-4 bg-white rounded-xl border border-gray-200">
+          <span className="text-xs text-gray-500 block mb-1">Total Brands</span>
+          <span className="text-2xl font-bold text-gray-900">{brands.length}</span>
+        </div>
+        <div className="p-4 bg-white rounded-xl border border-gray-200">
