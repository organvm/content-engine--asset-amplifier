# Database
DATABASE_URL=postgresql://cronus:cronus_dev@localhost:5432/cronus

# Redis
REDIS_URL=redis://localhost:6379

# Storage (MinIO / S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=cronus-assets
STORAGE_REGION=us-east-1

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default

# AI Providers — free-first, all roads available
# Local (no key needed — just install ollama.com)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Free cloud (sign up, get free API key)
GROQ_API_KEY=                    # console.groq.com — fastest, free Whisper transcription
GEMINI_API_KEY=                  # aistudio.google.com — Gemini 2.0 Flash free
CEREBRAS_API_KEY=                # cloud.cerebras.ai — fast inference free tier

# Free cloud (existing accounts)
CLOUDFLARE_ACCOUNT_ID=           # dash.cloudflare.com — Workers AI free tier
CLOUDFLARE_API_TOKEN=            # Cloudflare API token with Workers AI permission

# Paid cloud (optional upgrade)
ANTHROPIC_API_KEY=               # console.anthropic.com — Claude (highest quality)
OPENAI_API_KEY=                  # platform.openai.com — embeddings + Whisper

# Stripe
STRIPE_SECRET_KEY=               # dashboard.stripe.com — secret key
STRIPE_WEBHOOK_SECRET=           # stripe listen --forward-to localhost:3000/api/v1/billing/webhook
STRIPE_PRICE_ID_CREATOR=         # Creator tier price ID (price_xxx)
STRIPE_PRICE_ID_STUDIO=          # Studio tier price ID (price_xxx)

# API
API_PORT=3000
API_HOST=0.0.0.0
API_KEY=your-api-key-here # allow-secret

# Security
ENCRYPTION_KEY=your-encryption-key-here

# URLs
DASHBOARD_URL=http://localhost:5173
API_URL=http://localhost:3000

# Environment
NODE_ENV=development
LOG_LEVEL=debug
